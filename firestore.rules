rules_version = '2';
// DRAFT — tighten before production. Deploy: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && userDoc().data.role == 'Admin';
    }

    match /schools/{schoolId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /grade_levels/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /class_rooms/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /subjects/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /class_subjects/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /children/{studentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /enrollments/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
